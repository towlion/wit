{$APP_DOMAIN} {
    handle /api/* {
        reverse_proxy app:8000
    }
    handle /health {
        reverse_proxy app:8000
    }
    handle /docs {
        reverse_proxy app:8000
    }
    handle /redoc {
        reverse_proxy app:8000
    }
    handle /openapi.json {
        reverse_proxy app:8000
    }
    handle {
        reverse_proxy frontend:3000
    }
}
